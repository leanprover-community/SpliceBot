# Job-bound markers for the composite-action harness.
# Format: <job-name> :: <log marker that must appear on a line tagged with that job>
# act prefixes every log line with the job name, so the runner asserts that one
# line contains both the job name and the marker. This proves each job reaches
# (and fails at) the stage its name claims, not merely that it failed somewhere.
invalid-bridge-override-json :: override_json must be a JSON object
representative-auth-denial :: not authorized to trigger splice-bot
invalid-label-command-config-fails-early :: Could not parse label_commands
label-command-path-enters-split-flow :: Authorized label command 'ready'
comment-command-path-enters-split-flow :: Authorized label command 'maintainer-merge'
args-command-path-enters-split-flow :: Authorized label command 'maintainer'
invalid-command-args-fails-early :: Argument 'rebase' is not allowed for command 'maintainer'
stale-bridge-without-args-resolves-from-body :: Authorized label command 'maintainer'
edited-comment-without-trigger-noops :: nothing to do
splice-path-reaches-late-workflow-steps :: Check out BASE
